[Unit]
Description=CAPA PVL Hetzner API
After=network.target postgresql.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/projects/capapvl.pt
EnvironmentFile=/etc/capapvl-api.env
ExecStart=/usr/local/bin/bun run server/capa-api.ts
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
