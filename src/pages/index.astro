---
import Layout from '../layouts/Layout.astro';
import PlayfulLandingPage from '../components/test-landing/PlayfulLandingPage.astro';

const locale = 'pt' as const;
---

<Layout
  locale={locale}
  title="CAPA Póvoa de Lanhoso — Adota um Cão"
  description="CAPA Póvoa de Lanhoso — Abrigo de cães sem fins lucrativos. Adote um cão resgatado e dê-lhe uma segunda oportunidade."
