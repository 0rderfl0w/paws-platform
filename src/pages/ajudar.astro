---
import Layout from '../layouts/Layout.astro';
import PlayfulSiteNav from '../components/playful/PlayfulSiteNav.astro';
import PlayfulSiteFooter from '../components/playful/PlayfulSiteFooter.astro';
import AjudarPlayfulHero from '../components/ajudar/AjudarPlayfulHero.astro';
import AjudarDonationNeeds from '../components/ajudar/AjudarDonationNeeds.astro';
import AjudarVolunteerWays from '../components/ajudar/AjudarVolunteerWays.astro';
import AjudarFosterFamilies from '../components/ajudar/AjudarFosterFamilies.astro';
import AjudarFinancialDonations from '../components/ajudar/AjudarFinancialDonations.astro';
import AjudarFinalCta from '../components/ajudar/AjudarFinalCta.astro';

const locale = 'pt' as const;
---

<Layout
  locale={locale}
  title="Como Ajudar — CAPA Póvoa de Lanhoso"
  description="Descubra como pode ajudar o CAPA através de donativos, voluntariado ou acolhimento temporário."
  ogUrl="https://capapvl.org/ajudar"
  ogImage="/images/ajudar/hero-playful-help-fallback.jpg"
  playfulFonts
>
  <div data-playful-scroll-reveal class="min-h-screen bg-playful-canvas text-playful-ink font-playful-body pattern-dots selection:bg-playful-orange selection:text-white">
    <PlayfulSiteNav locale={locale} />
    <div class="overflow-x-clip">
      <main>
        <AjudarPlayfulHero />
        <AjudarDonationNeeds />
        <AjudarVolunteerWays />
        <AjudarFosterFamilies />
        <AjudarFinancialDonations />
        <AjudarFinalCta />
      </main>
      <PlayfulSiteFooter locale={locale} />
    </div>
  </div>

  <script>
    const revealRoot = document.querySelector('[data-playful-scroll-reveal]');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const revealDelayValue = (value: string | undefined) => {
      if (!value) return undefined;
      return /^\d+$/.test(value) ? `${value}ms` : value;
    };

    if (revealRoot) {
      const revealItems = new WeakSet<Element>();
      let observer: IntersectionObserver | null = null;

      const applyReveal = (item: Element) => {
        if (revealItems.has(item)) return;
        revealItems.add(item);

        item.classList.add('playful-reveal');

        const explicitDelay = revealDelayValue((item as HTMLElement).dataset.revealDelay);
        const group = item.parentElement?.closest('[data-reveal-stagger]') as HTMLElement | null;

        if (explicitDelay) {
          (item as HTMLElement).style.setProperty('--reveal-delay', explicitDelay);
        } else if (group) {
          const groupItems = Array.from(group.querySelectorAll('[data-reveal]')).filter((child) => child.parentElement?.closest('[data-reveal-stagger]') === group);
          const index = Math.max(0, groupItems.indexOf(item));
          const step = Number(group.dataset.revealStagger || 90);
          (item as HTMLElement).style.setProperty('--reveal-delay', `${Math.min(index * step, 420)}ms`);
        }

        if (reduceMotion || !observer) {
          item.classList.add('is-visible');
          return;
        }

        observer.observe(item);
      };

      if (!reduceMotion && 'IntersectionObserver' in window) {
        observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!entry.isIntersecting) return;
            entry.target.classList.add('is-visible');
            observer?.unobserve(entry.target);
          });
        }, { rootMargin: '0px 0px -4% 0px', threshold: 0.08 });
      }

      revealRoot.querySelectorAll('[data-reveal]').forEach(applyReveal);

      const mutationObserver = new MutationObserver((mutations) => {
        mutations.forEach((mutation) => {
          mutation.addedNodes.forEach((node) => {
            if (!(node instanceof Element)) return;
            if (node.matches('[data-reveal]')) applyReveal(node);
            node.querySelectorAll('[data-reveal]').forEach(applyReveal);
          });
        });
      });

      mutationObserver.observe(revealRoot, { childList: true, subtree: true });
    }
  </script>
</Layout>
