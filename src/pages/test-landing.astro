---
import Layout from '../layouts/Layout.astro';
import PlayfulLandingPage from '../components/test-landing/PlayfulLandingPage.astro';

const locale = 'pt' as const;
---

<Layout
  locale={locale}
  title="CAPA Póvoa de Lanhoso — Test Landing"
  description="Página de teste para a nova direção visual Playful Impact da CAPA Póvoa de Lanhoso."
  ogUrl="https://capapvl.org/test-landing/"
  noindex
  playfulFonts
>
  <PlayfulLandingPage locale={locale} homePath="/test-landing" />
</Layout>
