---
import Layout from '../layouts/Layout.astro';
import PlayfulNav from '../components/test-landing/PlayfulNav.astro';
import PlayfulHero from '../components/test-landing/PlayfulHero.astro';
import PlayfulStats from '../components/test-landing/PlayfulStats.astro';
import PlayfulWhyAdopt from '../components/test-landing/PlayfulWhyAdopt.astro';
import PlayfulFeaturedDogs from '../components/test-landing/PlayfulFeaturedDogs';
import PlayfulAboutBlurb from '../components/test-landing/PlayfulAboutBlurb.astro';
import PlayfulHelpCta from '../components/test-landing/PlayfulHelpCta.astro';
import PlayfulFooter from '../components/test-landing/PlayfulFooter.astro';
import PlayfulScrollReveal from '../components/playful/PlayfulScrollReveal.astro';

const locale = 'pt' as const;
---

<Layout
  locale={locale}
  title="CAPA Póvoa de Lanhoso — Test Landing"
  description="Página de teste para a nova direção visual Playful Impact da CAPA Póvoa de Lanhoso."
  ogUrl="https://capapvl.org/test-landing/"
  noindex
  playfulFonts
>
  <div data-playful-scroll-reveal class="min-h-screen bg-playful-canvas text-playful-ink font-playful-body pattern-dots selection:bg-playful-orange selection:text-white">
    <PlayfulNav locale={locale} />
    <div class="overflow-x-clip">
      <main>
        <PlayfulHero locale={locale} />
        <PlayfulStats locale={locale} />
        <PlayfulWhyAdopt locale={locale} />
        <PlayfulFeaturedDogs locale={locale} client:visible />
        <PlayfulAboutBlurb locale={locale} />
        <PlayfulHelpCta locale={locale} />
      </main>
      <PlayfulFooter locale={locale} />
    </div>
  </div>

  <PlayfulScrollReveal observeDynamic />
</Layout>
