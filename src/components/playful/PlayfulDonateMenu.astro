---
import type { Locale } from '../../i18n';

interface Props {
  locale?: Locale;
  variant?: 'desktop' | 'mobile';
  mode?: 'menu' | 'mbway-button' | 'card-menu';
  instanceId?: string;
  buttonLabel?: string;
  cardClass?: string;
}

const {
  locale = 'pt',
  variant = 'desktop',
  mode = 'menu',
  instanceId = `donate-${locale}-${variant}`,
  buttonLabel,
  cardClass = 'card-pillowy playful-focus block w-full rounded-playful border border-playful-line/70 bg-playful-cream p-7 text-center shadow-pillowy',
} = Astro.props;

const paypalDonateUrl = 'https://www.paypal.com/donate/?cmd=_s-xclick&hosted_button_id=W6QJXB42XRY4G&source=urlw&ssrt=1782128512360';
const shelterEmail = 'capa.geralpvl@gmail.com';
const bankTransferHref = locale === 'pt' ? '/ajudar#apoio-financeiro' : '/en/help#financial-support';

const labels = locale === 'pt'
  ? {
      donate: 'Doar',
      dropdownLabel: 'Opções de donativo',
      paypal: 'PayPal',
      paypalDesc: 'Doar agora numa nova página',
      mbway: 'MB Way',
      mbwayDesc: 'Pedir número por telefone',
      bankTransfer: 'Transferência bancária',
      bankTransferDesc: 'Ver IBAN e dados no fundo da página',
      mbwayTitle: 'Donativo por MB Way',
      mbwayIntro: 'Vamos enviar-lhe uma mensagem com o número de telefone para onde pode enviar o MB Way.',
      phoneLabel: 'O seu número de telefone',
      phonePlaceholder: '+351 912 345 678',
      submit: 'Pedir número MB Way',
      close: 'Fechar',
      fallbackNote: 'Se o email não abriu automaticamente, use este botão para enviar o pedido à CAPA.',
      fallback: 'Abrir email preparado',
      subject: 'Pedido de número MB Way para donativo',
      bodyIntro: 'Pedido de número MB Way para donativo através do site CAPA.',
      phoneBodyLabel: 'Telefone para contacto',
      pageLabel: 'Página',
    }
  : {
      donate: 'Donate',
      dropdownLabel: 'Donation options',
      paypal: 'PayPal',
      paypalDesc: 'Donate now in a new page',
      mbway: 'MB Way',
      mbwayDesc: 'Request the number by phone',
      bankTransfer: 'Bank transfer',
      bankTransferDesc: 'See IBAN and details at the bottom of the page',
      mbwayTitle: 'MB Way donation',
      mbwayIntro: 'We will message you with the phone number where you can send the MB Way.',
      phoneLabel: 'Your phone number',
      phonePlaceholder: '+351 912 345 678',
      submit: 'Request MB Way number',
      close: 'Close',
      fallbackNote: 'If the email did not open automatically, use this button to send the request to CAPA.',
      fallback: 'Open prepared email',
      subject: 'MB Way donation number request',
      bodyIntro: 'MB Way donation number request from the CAPA website.',
      phoneBodyLabel: 'Contact phone',
      pageLabel: 'Page',
    };

const menuId = `${instanceId}-menu`;
const buttonId = `${instanceId}-button`;
const dialogId = `${instanceId}-mbway-dialog`;

const buttonClass = variant === 'desktop'
  ? 'squishy playful-focus inline-flex items-center gap-2 rounded-full bg-playful-orange px-5 py-3 text-sm font-extrabold text-white shadow-squish'
  : 'playful-focus flex w-full items-center justify-center gap-2 rounded-full bg-playful-orange px-5 py-3 text-center text-sm font-extrabold text-white shadow-squish';

const panelClass = mode === 'card-menu'
  ? 'absolute bottom-full left-1/2 z-[80] mb-3 w-[min(18rem,calc(100vw-2rem))] -translate-x-1/2 rounded-[1.5rem] border border-playful-line bg-white/96 p-2 text-left shadow-pillowy-lg backdrop-blur-md'
  : variant === 'desktop'
    ? 'absolute right-0 top-full z-[80] mt-3 w-72 rounded-[1.5rem] border border-playful-line bg-white/96 p-2 text-left shadow-pillowy-lg backdrop-blur-md'
    : 'mt-3 w-full rounded-[1.5rem] border border-playful-line bg-white/92 p-2 text-left shadow-pillowy';

const itemClass = 'playful-focus flex w-full items-start gap-3 rounded-[1.1rem] px-4 py-3 text-left transition-colors hover:bg-playful-peach/70';
const standaloneButtonLabel = buttonLabel ?? labels.submit;
---

{mode === 'menu' || mode === 'card-menu' ? (
  <div data-donate-menu={instanceId} class="relative">
    <button
      id={buttonId}
      data-donate-toggle
      data-reveal={mode === 'card-menu' ? 'tilt' : undefined}
      type="button"
      class={mode === 'card-menu' ? `${cardClass} cursor-pointer appearance-none` : buttonClass}
      aria-haspopup="menu"
      aria-expanded="false"
      aria-controls={menuId}
    >
      {mode === 'card-menu' ? (
        <slot />
      ) : (
        <>
          <span>{labels.donate}</span>
          <span aria-hidden="true">❤</span>
          <span data-donate-chevron aria-hidden="true" class="text-xs transition-transform">▾</span>
        </>
      )}
    </button>

    <div id={menuId} data-donate-panel class={`${panelClass} hidden`} role="menu" aria-labelledby={buttonId}>
      <a data-donate-paypal role="menuitem" href={paypalDonateUrl} target="_blank" rel="noopener noreferrer" class={itemClass}>
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-playful-orange/14 text-sm font-extrabold text-playful-orange-dark" aria-hidden="true">◈</span>
        <span>
          <span class="block font-playful-display text-sm font-extrabold text-playful-orange-dark">{labels.paypal}</span>
          <span class="mt-0.5 block text-xs font-bold leading-5 text-playful-muted">{labels.paypalDesc}</span>
        </span>
      </a>

      <button data-mbway-open={instanceId} role="menuitem" type="button" class={itemClass}>
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-playful-orange/14 text-sm font-extrabold text-playful-orange-dark" aria-hidden="true">▯</span>
        <span>
          <span class="block font-playful-display text-sm font-extrabold text-playful-orange-dark">{labels.mbway}</span>
          <span class="mt-0.5 block text-xs font-bold leading-5 text-playful-muted">{labels.mbwayDesc}</span>
        </span>
      </button>

      <a data-donate-bank role="menuitem" href={bankTransferHref} class={itemClass}>
        <span class="mt-0.5 flex h-9 w-9 shrink-0 items-center justify-center rounded-full bg-playful-orange/14 text-sm font-extrabold text-playful-orange-dark" aria-hidden="true">↴</span>
        <span>
          <span class="block font-playful-display text-sm font-extrabold text-playful-orange-dark">{labels.bankTransfer}</span>
          <span class="mt-0.5 block text-xs font-bold leading-5 text-playful-muted">{labels.bankTransferDesc}</span>
        </span>
      </a>
    </div>
  </div>
) : (
  <button
    data-mbway-open={instanceId}
    type="button"
    class="squishy playful-focus mt-5 inline-flex items-center justify-center gap-2 rounded-full bg-playful-orange px-5 py-3 font-playful-display text-sm font-extrabold text-white shadow-squish"
  >
    <span>{standaloneButtonLabel}</span>
    <span aria-hidden="true">▯</span>
  </button>
)}

<dialog data-mbway-modal={instanceId} id={dialogId} aria-labelledby={`${dialogId}-title`} aria-describedby={`${dialogId}-intro`} class="w-[calc(100%-2rem)] max-w-lg rounded-[2rem] bg-transparent p-0 text-left text-playful-ink">
  <div class="relative rounded-[2rem] border-2 border-playful-line bg-playful-canvas p-5 shadow-pillowy-lg sm:p-7">
    <button data-mbway-close={instanceId} type="button" class="playful-focus absolute right-4 top-4 rounded-full border border-playful-line bg-white px-3 py-2 text-sm font-extrabold text-playful-orange-dark shadow-sm" aria-label={labels.close}>
      ×
    </button>

    <span class="text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">MB Way</span>
    <h2 id={`${dialogId}-title`} class="mt-2 pr-10 font-playful-display text-3xl font-extrabold tracking-[-0.03em] text-playful-orange-dark">{labels.mbwayTitle}</h2>
    <p id={`${dialogId}-intro`} class="mt-3 text-sm font-semibold leading-7 text-playful-muted sm:text-base">{labels.mbwayIntro}</p>

    <form data-mbway-form={instanceId} class="mt-6 grid gap-4" novalidate>
      <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
        {labels.phoneLabel}
        <input name="mbway_phone" required type="tel" autocomplete="tel" placeholder={labels.phonePlaceholder} class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold text-playful-ink shadow-sm" />
      </label>

      <div data-mbway-mailto-note={instanceId} class="hidden rounded-2xl border border-playful-line bg-white p-4 text-sm font-bold leading-6 text-playful-muted">
        <p>{labels.fallbackNote}</p>
        <a data-mbway-mailto={instanceId} href={`mailto:${shelterEmail}`} class="playful-focus mt-3 inline-flex rounded-full bg-playful-orange px-5 py-3 font-playful-display text-sm font-extrabold text-white shadow-squish">
          {labels.fallback}
        </a>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
        <button data-mbway-close={instanceId} type="button" class="playful-focus rounded-full border-2 border-playful-orange bg-white px-6 py-3 font-playful-display text-sm font-extrabold text-playful-orange-dark shadow-pillowy">
          {labels.close}
        </button>
        <button type="submit" class="squishy playful-focus rounded-full bg-playful-orange px-6 py-3 font-playful-display text-sm font-extrabold text-white shadow-squish">
          {labels.submit}
        </button>
      </div>
    </form>
  </div>
</dialog>

<style is:global>
  dialog[data-mbway-modal]::backdrop {
    background: rgb(29 27 22 / 0.54);
    backdrop-filter: blur(7px);
  }
</style>

<script define:vars={{ instanceId, shelterEmail, labels, variant }}>
  const donateRoot = document.querySelector(`[data-donate-menu="${instanceId}"]`);
  const donateToggle = donateRoot?.querySelector('[data-donate-toggle]');
  const donatePanel = donateRoot?.querySelector('[data-donate-panel]');
  const donateChevron = donateRoot?.querySelector('[data-donate-chevron]');
  const mbwayDialog = document.querySelector(`[data-mbway-modal="${instanceId}"]`);
  const mbwayForm = document.querySelector(`[data-mbway-form="${instanceId}"]`);
  const mbwayMailto = document.querySelector(`[data-mbway-mailto="${instanceId}"]`);
  const mbwayMailtoNote = document.querySelector(`[data-mbway-mailto-note="${instanceId}"]`);
  const mbwayOpenButton = document.querySelector(`[data-mbway-open="${instanceId}"]`);

  const setDonateOpen = (isOpen) => {
    donatePanel?.classList.toggle('hidden', !isOpen);
    donateToggle?.setAttribute('aria-expanded', String(isOpen));
    donateChevron?.classList.toggle('rotate-180', isOpen);
  };

  donateToggle?.addEventListener('click', (event) => {
    event.stopPropagation();
    const shouldOpen = donatePanel?.classList.contains('hidden') ?? true;
    setDonateOpen(shouldOpen);
    if (shouldOpen && variant === 'mobile') {
      window.requestAnimationFrame(() => {
        donatePanel?.scrollIntoView({ block: 'nearest', inline: 'nearest' });
      });
    }
  });

  donatePanel?.addEventListener('click', (event) => {
    event.stopPropagation();
  });

  document.addEventListener('click', (event) => {
    if (!donateRoot?.contains(event.target)) setDonateOpen(false);
  });

  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') setDonateOpen(false);
  });

  donatePanel?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => setDonateOpen(false));
  });

  mbwayOpenButton?.addEventListener('click', () => {
    setDonateOpen(false);
    if (typeof mbwayDialog?.showModal === 'function') mbwayDialog.showModal();
    else mbwayDialog?.setAttribute('open', '');
    mbwayDialog?.querySelector('input')?.focus();
  });

  document.querySelectorAll(`[data-mbway-close="${instanceId}"]`).forEach((button) => {
    button.addEventListener('click', () => {
      if (typeof mbwayDialog?.close === 'function') mbwayDialog.close();
      else mbwayDialog?.removeAttribute('open');
    });
  });

  mbwayDialog?.addEventListener('click', (event) => {
    if (event.target === mbwayDialog) {
      if (typeof mbwayDialog.close === 'function') mbwayDialog.close();
      else mbwayDialog.removeAttribute('open');
    }
  });

  mbwayForm?.addEventListener('submit', (event) => {
    event.preventDefault();
    if (!mbwayForm.reportValidity()) return;
    const data = new FormData(mbwayForm);
    const phone = String(data.get('mbway_phone') ?? '').trim();
    const body = [
      labels.bodyIntro,
      '',
      `${labels.phoneBodyLabel}: ${phone}`,
      `${labels.pageLabel}: ${window.location.href}`,
    ].join('\n');
    const mailto = `mailto:${shelterEmail}?subject=${encodeURIComponent(labels.subject)}&body=${encodeURIComponent(body)}`;
    mbwayMailto?.setAttribute('href', mailto);
    mbwayMailtoNote?.classList.remove('hidden');
    mbwayMailto?.focus();

    if (mbwayForm.dataset.skipMailLaunch !== 'true') {
      window.location.href = mailto;
    }
  });
</script>
