---
import { getTranslations, type Locale } from '../../i18n';
import VisitSchedule from '../VisitSchedule';
import BrandIcon from '../BrandIcon.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);

const homePath = locale === 'pt' ? '/' : '/en/';
const dogsPath = locale === 'pt' ? '/caes' : '/en/dogs';
const adoptPath = locale === 'pt' ? '/adocao' : '/en/adopt';
const aboutPath = locale === 'pt' ? '/sobre-nos' : '/en/about';
const helpPath = locale === 'pt' ? '/ajudar' : '/en/help';
const footerAriaLabel = locale === 'pt' ? 'Rodapé' : 'Footer';
const facebookLabel = locale === 'pt' ? 'CAPA no Facebook' : 'CAPA on Facebook';
const instagramLabel = locale === 'pt' ? 'CAPA no Instagram' : 'CAPA on Instagram';
const iban = 'PT50 0010 0000 4591 4000 0014 9';
const mapsHref = 'https://maps.app.goo.gl/vjuwcaWTdFS4YzARA';
const mapsLabel = locale === 'pt' ? 'Abrir localização da CAPA no Google Maps' : 'Open CAPA location in Google Maps';

const quickLinks = [
  { href: homePath, label: t.nav.home },
  { href: dogsPath, label: t.nav.dogs },
  { href: adoptPath, label: t.footer.adoption },
  { href: aboutPath, label: t.nav.about },
  { href: helpPath, label: t.footer.howToHelp },
];

const helpLinks = [
  { href: adoptPath, label: t.footer.adoptDog },
  { href: helpPath, label: t.footer.volunteering },
  { href: helpPath, label: t.footer.fosterFamilies },
  { href: helpPath, label: t.footer.donate },
];
---

<footer data-reveal="rise" class="relative overflow-hidden rounded-t-[3rem] bg-playful-peach text-playful-muted shadow-pillowy-lg" aria-label={footerAriaLabel}>
  <div class="ambient-blob -left-24 top-10 h-72 w-72 bg-white"></div>
  <div class="ambient-blob -right-16 bottom-6 h-80 w-80 bg-playful-orange/25"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-5 py-16 sm:px-8">
    <div data-reveal-stagger="80" class="grid gap-10 lg:grid-cols-[1.2fr_0.7fr_1fr_0.75fr_0.9fr]">
      <div data-reveal="left">
        <a href={homePath} class="playful-focus inline-flex items-center gap-4 rounded-full">
          <img src="/logo.jpg" alt="CAPA Póvoa de Lanhoso" class="h-20 w-20 rounded-[1.75rem] border-4 border-white object-cover shadow-pillowy" width="80" height="80" />
          <div>
            <div class="font-playful-display text-3xl font-extrabold tracking-[-0.04em] text-playful-orange-dark">CAPAPVL</div>
            <div class="text-xs font-extrabold uppercase tracking-[0.18em] text-playful-muted">Póvoa de Lanhoso</div>
          </div>
        </a>
        <p class="mt-5 max-w-sm text-sm font-medium leading-7">{t.footer.brandDesc}</p>
        <div class="mt-5 flex gap-3">
          <a href="https://facebook.com/capapvl" class="squishy playful-focus flex h-11 w-11 items-center justify-center rounded-full bg-playful-orange text-white shadow-sm" aria-label={facebookLabel} target="_blank" rel="noopener noreferrer"><BrandIcon name="facebook" class="h-5 w-5" /></a>
          <a href="https://instagram.com/capapvl" class="squishy playful-focus flex h-11 w-11 items-center justify-center rounded-full bg-playful-orange text-white shadow-sm" aria-label={instagramLabel} target="_blank" rel="noopener noreferrer"><BrandIcon name="instagram" class="h-5 w-5" /></a>
        </div>
      </div>

      <div data-reveal="rise">
        <h3 class="font-playful-display text-lg font-extrabold text-playful-orange-dark">{t.footer.navHeading}</h3>
        <ul class="mt-4 space-y-2" role="list">
          {quickLinks.map(({ href, label }) => (
            <li><a href={href} class="playful-focus inline-block rounded-full px-1 py-1 text-sm font-bold hover:text-playful-orange-dark">{label}</a></li>
          ))}
        </ul>
      </div>

      <div data-reveal="rise" data-footer-visit>
        <h3 class="font-playful-display text-lg font-extrabold text-playful-orange-dark">{t.footer.visitHeading}</h3>
        <p class="mt-4 text-sm font-semibold leading-6 text-playful-muted">{t.footer.visitPrompt}</p>
        <a
          href={mapsHref}
          data-footer-visit-map
          class="playful-focus group mt-4 block overflow-hidden rounded-[1.5rem] border border-playful-orange/20 bg-white/78 p-3 shadow-sm transition hover:-translate-y-0.5 hover:shadow-pillowy"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={mapsLabel}
        >
          <span class="relative flex min-h-28 items-center justify-center overflow-hidden rounded-[1.1rem] bg-[linear-gradient(135deg,rgba(255,138,31,0.16),rgba(83,134,58,0.18)),repeating-linear-gradient(45deg,rgba(111,78,55,0.12)_0_1px,transparent_1px_18px)]">
            <span class="absolute left-4 top-4 h-12 w-20 rounded-full border-2 border-white/80 bg-white/35 rotate-[-14deg]"></span>
            <span class="absolute bottom-4 right-5 h-10 w-24 rounded-full border-2 border-white/80 bg-white/35 rotate-[10deg]"></span>
            <span class="relative flex h-14 w-14 items-center justify-center rounded-full bg-playful-orange text-white shadow-squish transition group-hover:scale-105">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="h-8 w-8" aria-hidden="true">
                <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 10-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
              </svg>
            </span>
          </span>
          <span class="mt-3 block text-xs font-extrabold uppercase tracking-[0.18em] text-playful-orange-dark">{t.footer.visitMapEyebrow}</span>
          <span class="mt-1 block text-sm font-extrabold text-playful-ink">{t.footer.visitMapLabel}</span>
        </a>
        <VisitSchedule locale={locale} source="footer" client:idle />
      </div>

      <div data-reveal="rise">
        <h3 class="font-playful-display text-lg font-extrabold text-playful-orange-dark">{t.footer.helpHeading}</h3>
        <ul class="mt-4 space-y-2" role="list">
          {helpLinks.map(({ href, label }) => (
            <li><a href={href} class="playful-focus inline-block rounded-full px-1 py-1 text-sm font-bold hover:text-playful-orange-dark">{label}</a></li>
          ))}
        </ul>
      </div>

      <div data-reveal="right">
        <h3 class="font-playful-display text-lg font-extrabold text-playful-orange-dark">{t.footer.contactHeading}</h3>
        <ul class="mt-4 space-y-3 text-sm font-medium leading-6" role="list" data-footer-contact>
          <li><a href="tel:+351253690000" class="playful-focus hover:text-playful-orange-dark">+351 253 690 000</a></li>
          <li><a href="mailto:capa.geralpvl@gmail.com" class="playful-focus hover:text-playful-orange-dark">capa.geralpvl@gmail.com</a></li>
        </ul>
      </div>

      <div data-reveal="rise" class="lg:col-start-3 lg:col-span-3 lg:-mt-3">
        <div class="w-full rounded-[2rem] bg-white/75 px-4 py-4 text-center text-xs font-bold leading-relaxed shadow-sm sm:rounded-full sm:px-6 sm:py-3 xl:text-sm" data-footer-iban>
          <p class="mx-auto flex max-w-full flex-col items-center justify-center gap-1.5 text-playful-ink sm:flex-row sm:gap-0">
            <span class="font-extrabold text-playful-orange-dark">{t.footer.supportCapa}</span>
            <span class="hidden mx-2 text-playful-orange/60 sm:inline" aria-hidden="true">·</span>
            <span class="max-w-full whitespace-normal break-words font-mono text-[0.82rem] font-extrabold leading-6 tracking-[-0.03em] sm:whitespace-nowrap sm:text-xs sm:tracking-[-0.04em] xl:text-sm" data-footer-iban-value>IBAN: {iban}</span>
          </p>
        </div>
      </div>
    </div>

    <div data-reveal="rise" class="mt-12 border-t border-playful-orange/15 pt-8 text-center text-xs font-bold text-playful-muted/80">
      <p>{t.footer.copyright}</p>
      <p class="mt-2" data-footer-richkapp-credit>
        {t.footer.madeWith}{' '}
        <a
          href="https://richkapp.com/websites"
          data-footer-richkapp-link
          class="playful-focus underline decoration-playful-orange/45 decoration-2 underline-offset-4 hover:text-playful-orange-dark"
          target="_blank"
          rel="noopener noreferrer"
        >RichKapp</a>
      </p>
    </div>
  </div>
</footer>
