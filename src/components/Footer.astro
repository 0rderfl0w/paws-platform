---
import { getTranslations, type Locale } from '../i18n';
import BrandIcon from './BrandIcon.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);

const homePath = locale === 'pt' ? '/' : '/en/';
const dogsPath = locale === 'pt' ? '/caes' : '/en/dogs';
const adoptPath = locale === 'pt' ? '/adocao' : '/en/adopt';
const aboutPath = locale === 'pt' ? '/sobre-nos' : '/en/about';
const helpPath = locale === 'pt' ? '/ajudar' : '/en/help';
const mapsHref = 'https://maps.app.goo.gl/vjuwcaWTdFS4YzARA';
const mapsLabel = locale === 'pt' ? 'Abrir localização da CAPA no Google Maps' : 'Open CAPA location in Google Maps';

const quickLinks = [
  { href: homePath, label: t.nav.home },
  { href: dogsPath, label: t.nav.dogs },
  { href: adoptPath, label: t.footer.adoption },
  { href: aboutPath, label: t.nav.about },
  { href: helpPath, label: t.footer.howToHelp },
];

const helpLinks = [
  { href: adoptPath, label: t.footer.adoptDog },
  { href: helpPath, label: t.footer.volunteering },
  { href: helpPath, label: t.footer.fosterFamilies },
  { href: helpPath, label: t.footer.donate },
];
---

<footer class="bg-warm-900 text-warm-200" aria-label="Rodapé">
  <!-- Brand section with prominent logo -->
  <div class="border-b border-warm-800">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
      <div class="flex flex-col sm:flex-row items-center sm:items-start gap-8">
        <!-- Logo -->
        <a href={homePath} class="flex-shrink-0" aria-label="CAPA Póvoa de Lanhoso — Página inicial">
          <img
            src="/logo.jpg"
            alt="CAPA Póvoa de Lanhoso"
            class="w-28 h-28 rounded-2xl object-cover shadow-lg"
            width="112"
            height="112"
          />
        </a>
        <!-- Name, description, socials -->
        <div class="flex-1 text-center sm:text-left">
          <div class="text-white font-bold text-2xl leading-tight mb-0.5">CAPA</div>
          <div class="text-warm-400 text-sm mb-4">Póvoa de Lanhoso</div>
          <p class="text-warm-400 text-sm leading-relaxed max-w-sm mb-6">
            {t.footer.brandDesc}
          </p>
          <div class="flex gap-3 justify-center sm:justify-start">
            <a
              href="https://facebook.com/capapvl"
              class="w-10 h-10 bg-warm-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors"
              aria-label="CAPA no Facebook"
              target="_blank"
              rel="noopener noreferrer"
            >
              <BrandIcon name="facebook" class="w-5 h-5" />
            </a>
            <a
              href="https://instagram.com/capapvl"
              class="w-10 h-10 bg-warm-800 hover:bg-primary-600 rounded-lg flex items-center justify-center transition-colors"
              aria-label="CAPA no Instagram"
              target="_blank"
              rel="noopener noreferrer"
            >
              <BrandIcon name="instagram" class="w-5 h-5" />
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Links + contact -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pt-12 pb-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-12">

      <!-- Quick links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t.footer.navHeading}</h3>
        <ul class="space-y-2" role="list">
          {quickLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-warm-400 hover:text-white text-sm transition-colors hover:translate-x-0.5 inline-block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Help links -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t.footer.helpHeading}</h3>
        <ul class="space-y-2" role="list">
          {helpLinks.map(({ href, label }) => (
            <li>
              <a href={href} class="text-warm-400 hover:text-white text-sm transition-colors hover:translate-x-0.5 inline-block">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-white font-semibold mb-4 text-sm uppercase tracking-wider">{t.footer.contactHeading}</h3>
        <ul class="space-y-3" role="list">
          <li class="flex items-start gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary-400 flex-shrink-0 mt-0.5" aria-hidden="true">
              <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 00.723 0l.028-.015.071-.041a16.975 16.975 0 001.144-.742 19.58 19.58 0 002.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 00-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 002.682 2.282 16.975 16.975 0 001.145.742zM12 13.5a3 3 0 100-6 3 3 0 000 6z" clip-rule="evenodd" />
            </svg>
            <a href={mapsHref} class="text-warm-400 hover:text-white text-sm transition-colors" target="_blank" rel="noopener noreferrer" aria-label={mapsLabel}>
              EN310 115<br />Póvoa de Lanhoso, Braga<br />Portugal
            </a>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary-400 flex-shrink-0" aria-hidden="true">
              <path fill-rule="evenodd" d="M1.5 4.5a3 3 0 013-3h1.372c.86 0 1.61.586 1.819 1.42l1.105 4.423a1.875 1.875 0 01-.694 1.955l-1.293.97c-.135.101-.164.249-.126.352a11.285 11.285 0 006.697 6.697c.103.038.25.009.352-.126l.97-1.293a1.875 1.875 0 011.955-.694l4.423 1.105c.834.209 1.42.959 1.42 1.82V19.5a3 3 0 01-3 3h-2.25C8.552 22.5 1.5 15.448 1.5 6.75V4.5z" clip-rule="evenodd" />
            </svg>
            <a href="tel:+351253690000" class="text-warm-400 hover:text-white text-sm transition-colors">+351 253 690 000</a>
          </li>
          <li class="flex items-center gap-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-5 h-5 text-primary-400 flex-shrink-0" aria-hidden="true">
              <path d="M1.5 8.67v8.58a3 3 0 003 3h15a3 3 0 003-3V8.67l-8.928 5.493a3 3 0 01-3.144 0L1.5 8.67z" />
              <path d="M22.5 6.908V6.75a3 3 0 00-3-3h-15a3 3 0 00-3 3v.158l9.714 5.978a1.5 1.5 0 001.572 0L22.5 6.908z" />
            </svg>
            <a href="mailto:capa.geralpvl@gmail.com" class="text-warm-400 hover:text-white text-sm transition-colors">capa.geralpvl@gmail.com</a>
          </li>
        </ul>
      </div>

    </div>

    <!-- Donation info -->
    <div class="border-t border-warm-800 pt-8 pb-8 mb-4">
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 text-center">
        <div>
          <h3 class="text-white font-semibold text-sm uppercase tracking-wider mb-2">{t.footer.supportCapa}</h3>
          <p class="text-warm-400 text-sm">IBAN: <span class="text-warm-200 font-mono">PT50 0010 0000 4591 4000 0014 9</span></p>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-warm-800 pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-warm-500 text-sm">
        {t.footer.copyright}
      </p>
      <p class="text-warm-600 text-xs" data-footer-richkapp-credit>
        {t.footer.madeWith}{' '}
        <a
          href="https://richkapp.com/websites"
          data-footer-richkapp-link
          class="underline decoration-warm-500 decoration-2 underline-offset-4 hover:text-warm-300"
          target="_blank"
          rel="noopener noreferrer"
        >RichKapp</a>
      </p>
    </div>

  </div>
</footer>
