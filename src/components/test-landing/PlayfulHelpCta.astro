---
import { getTranslations, type Locale } from '../../i18n';
import PlayfulDonateMenu from '../playful/PlayfulDonateMenu.astro';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);
const helpPath = locale === 'pt' ? '/ajudar' : '/en/help';
const shelterEmail = 'capa.geralpvl@gmail.com';
const formApiBaseUrl = (import.meta.env.PUBLIC_CAPA_API_URL || '').replace(/\/$/, '');

const sponsorModal = locale === 'pt'
  ? {
      title: 'Apadrinhar mensalmente',
      eyebrow: 'Pedido de apadrinhamento',
      intro: 'Deixa-nos os detalhes do teu contributo. Ao enviar, abrimos um email já preenchido para a CAPA — basta confirmar e enviar no teu email.',
      name: 'Nome',
      email: 'Email',
      phone: 'Telefone (opcional)',
      business: 'É uma empresa?',
      businessYes: 'Sim, é uma empresa',
      businessNo: 'Não, particular',
      amount: 'Contributo mensal pretendido (€)',
      method: 'Forma preferida para contribuir',
      methodPlaceholder: 'Seleciona uma opção',
      methods: ['Transferência bancária', 'MB Way', 'PayPal', 'Prefiro que a CAPA me contacte'],
      message: 'Mensagem ou notas (opcional)',
      messagePlaceholder: 'Ex.: gostava de apadrinhar um cão específico, receber recibo, ou combinar os detalhes.',
      close: 'Fechar',
      submit: 'Enviar pedido à CAPA',
      sending: 'A enviar…',
      sent: 'Pedido enviado. A equipa da CAPA recebeu os dados e responderá por email.',
      fallback: 'Abrir email preparado',
      fallbackNote: 'Não conseguimos confirmar o envio automático. Usa este botão para enviar o email preparado à CAPA.',
      subject: 'Novo pedido de apadrinhamento mensal',
      bodyIntro: 'Novo pedido de apadrinhamento mensal através do site CAPA.',
      labels: {
        name: 'Nome',
        email: 'Email',
        phone: 'Telefone',
        business: 'Empresa',
        amount: 'Contributo mensal pretendido',
        method: 'Forma preferida para contribuir',
        message: 'Mensagem',
      },
      notProvided: 'Não indicado',
      perMonth: '/mês',
      page: 'Página',
    }
  : {
      title: 'Sponsor monthly',
      eyebrow: 'Sponsorship request',
      intro: 'Leave the details of your contribution. When you submit, we open a prefilled email to CAPA — just confirm and send it from your email app.',
      name: 'Name',
      email: 'Email',
      phone: 'Phone (optional)',
      business: 'Are you a business?',
      businessYes: 'Yes, this is a business',
      businessNo: 'No, individual sponsor',
      amount: 'Preferred monthly contribution (€)',
      method: 'Preferred way to contribute',
      methodPlaceholder: 'Choose an option',
      methods: ['Bank transfer', 'MB Way', 'PayPal', 'I would like CAPA to contact me'],
      message: 'Message or notes (optional)',
      messagePlaceholder: 'Example: I would like to sponsor a specific dog, receive a receipt, or discuss details.',
      close: 'Close',
      submit: 'Send request to CAPA',
      sending: 'Sending…',
      sent: 'Request sent. CAPA received the details and will reply by email.',
      fallback: 'Open prepared email',
      fallbackNote: 'We could not confirm automatic sending. Use this button to send the prepared email to CAPA.',
      subject: 'New monthly sponsorship request',
      bodyIntro: 'New monthly sponsorship request from the CAPA website.',
      labels: {
        name: 'Name',
        email: 'Email',
        phone: 'Phone',
        business: 'Business',
        amount: 'Preferred monthly contribution',
        method: 'Preferred way to contribute',
        message: 'Message',
      },
      notProvided: 'Not provided',
      perMonth: '/month',
      page: 'Page',
    };

const ways = [
  { title: t.helpCta.adoptTitle, description: t.helpCta.adoptDesc, icon: '⌂', href: locale === 'pt' ? '/adocao' : '/en/adopt', rotate: 'md:rotate-1', bg: 'bg-playful-peach', action: 'link' },
  { title: t.helpCta.sponsorTitle, description: t.helpCta.sponsorDesc, icon: '🤝', href: helpPath, rotate: 'md:-rotate-1 md:translate-y-7', bg: 'bg-white', action: 'sponsor' },
  { title: t.helpCta.volunteerTitle, description: t.helpCta.volunteerDesc, icon: '✋', href: helpPath, rotate: 'md:rotate-2', bg: 'bg-white', action: 'link' },
  { title: t.helpCta.donateTitle, description: t.helpCta.donateDesc, icon: '❤', href: helpPath, rotate: 'md:-rotate-2 md:translate-y-4', bg: 'bg-playful-cream', action: 'donate' },
];
---

<section id="ajudar" class="relative px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="playful-help-heading">
  <div class="ambient-blob right-0 top-16 h-72 w-72 bg-playful-peach"></div>
  <div class="mx-auto max-w-7xl">
    <header data-reveal="rise" class="relative z-10 mb-12 text-center">
      <span class="mb-3 inline-block text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{t.helpCta.eyebrow}</span>
      <h2 id="playful-help-heading" class="mx-auto max-w-4xl -rotate-1 font-playful-display text-4xl font-extrabold tracking-[-0.04em] text-playful-orange-dark sm:text-5xl">
        {t.helpCta.heading}
        <span aria-hidden="true"> 🐾</span>
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium leading-8 text-playful-muted">{t.helpCta.subheading}</p>
    </header>

    <div data-reveal-stagger="90" class="relative z-10 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
      {ways.map(({ title, description, icon, href, rotate, bg, action }, index) => {
        const cardClass = `${bg} ${rotate} card-pillowy playful-focus block w-full rounded-playful border border-playful-line/70 p-7 text-center shadow-pillowy`;
        const cardContent = (
          <>
            <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-playful-orange/14 text-2xl shadow-sm" aria-hidden="true">{icon}</div>
            <div class="mb-2 text-xs font-extrabold uppercase tracking-[0.18em] text-playful-orange-dark">{index + 1}. {title}</div>
            <p class="text-sm font-medium leading-6 text-playful-muted">{description}</p>
          </>
        );

        return action === 'sponsor' ? (
          <button
            data-reveal="tilt"
            data-sponsor-modal-open
            type="button"
            class={`${cardClass} cursor-pointer appearance-none`}
            aria-haspopup="dialog"
            aria-controls="sponsor-modal"
          >
            {cardContent}
          </button>
        ) : action === 'donate' ? (
          <PlayfulDonateMenu
            locale={locale}
            mode="card-menu"
            instanceId={`home-${locale}-donate-card`}
            cardClass={cardClass}
          >
            {cardContent}
          </PlayfulDonateMenu>
        ) : (
          <a data-reveal="tilt" href={href} class={cardClass}>
            {cardContent}
          </a>
        );
      })}
    </div>

    <div data-reveal="pop" class="relative z-10 mx-auto mt-12 max-w-3xl rounded-[2rem] border-2 border-playful-orange/15 bg-white p-6 shadow-pillowy-lg sm:p-8">
      <div class="grid items-center gap-6 sm:grid-cols-[auto_1fr]">
        <div class="mx-auto flex h-24 w-24 items-center justify-center rounded-full bg-playful-orange text-4xl text-white shadow-squish" aria-hidden="true">❤</div>
        <div class="text-center sm:text-left">
          <h3 class="font-playful-display text-2xl font-extrabold text-playful-orange-dark">{t.footer.supportCapa}</h3>
          <p class="mt-2 text-sm font-medium text-playful-muted">{t.helpCta.ctaFooter}</p>
          <div class="mt-4 inline-block rounded-full border-2 border-dashed border-playful-line bg-playful-cream px-4 py-3 font-mono text-[11px] font-extrabold tracking-tight text-playful-orange-dark whitespace-nowrap sm:px-5 sm:text-sm sm:tracking-wide">
            IBAN: PT50 0010 0000 4591 4000 0014 9
          </div>
        </div>
      </div>
    </div>

    <div data-reveal="rise" class="relative z-10 mt-10 text-center">
      <a href={helpPath} class="squishy playful-focus inline-flex items-center justify-center rounded-full bg-playful-orange px-8 py-4 font-playful-display font-extrabold text-white shadow-squish">
        {t.helpCta.ctaButton}
      </a>
    </div>
  </div>
</section>

<dialog data-sponsor-modal id="sponsor-modal" aria-labelledby="sponsor-modal-title" aria-describedby="sponsor-modal-intro" class="w-[calc(100%-2rem)] max-w-3xl rounded-[2rem] bg-transparent p-0 text-left text-playful-ink">
  <div class="relative max-h-[88vh] overflow-y-auto rounded-[2rem] border-2 border-playful-line bg-playful-canvas p-5 shadow-pillowy-lg sm:p-7">
    <button data-sponsor-modal-close type="button" class="playful-focus absolute right-4 top-4 rounded-full border border-playful-line bg-white px-3 py-2 text-sm font-extrabold text-playful-orange-dark shadow-sm" aria-label={sponsorModal.close}>
      ×
    </button>

    <div class="pr-10">
      <span class="text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{sponsorModal.eyebrow}</span>
      <h3 id="sponsor-modal-title" class="mt-2 font-playful-display text-3xl font-extrabold tracking-[-0.03em] text-playful-orange-dark sm:text-4xl">{sponsorModal.title}</h3>
      <p id="sponsor-modal-intro" class="mt-3 max-w-2xl text-sm font-semibold leading-7 text-playful-muted sm:text-base">{sponsorModal.intro}</p>
    </div>

    <form data-sponsor-form class="mt-7 grid gap-5" novalidate>
      <label class="hidden" aria-hidden="true">
        Website
        <input name="website" tabindex="-1" autocomplete="off" />
      </label>
      <div class="grid gap-4 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
          {sponsorModal.name}
          <input name="sponsor_name" required autocomplete="name" class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold text-playful-ink shadow-sm" />
        </label>
        <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
          {sponsorModal.email}
          <input name="sponsor_email" required type="email" autocomplete="email" class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold text-playful-ink shadow-sm" />
        </label>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
          {sponsorModal.phone}
          <input name="sponsor_phone" type="tel" autocomplete="tel" class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold text-playful-ink shadow-sm" />
        </label>
        <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
          {sponsorModal.amount}
          <input name="sponsor_amount" required type="number" inputmode="decimal" min="1" step="1" class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold text-playful-ink shadow-sm" />
        </label>
      </div>

      <fieldset class="rounded-2xl border border-playful-line bg-white/80 p-4">
        <legend class="px-1 text-sm font-extrabold text-playful-orange-dark">{sponsorModal.business}</legend>
        <div class="mt-3 grid gap-3 sm:grid-cols-2">
          <label class="flex items-center gap-3 rounded-2xl bg-playful-cream px-4 py-3 text-sm font-bold text-playful-muted">
            <input name="sponsor_business" required type="radio" value="yes" class="h-4 w-4 accent-playful-orange" />
            {sponsorModal.businessYes}
          </label>
          <label class="flex items-center gap-3 rounded-2xl bg-playful-cream px-4 py-3 text-sm font-bold text-playful-muted">
            <input name="sponsor_business" required type="radio" value="no" class="h-4 w-4 accent-playful-orange" />
            {sponsorModal.businessNo}
          </label>
        </div>
      </fieldset>

      <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
        {sponsorModal.method}
        <select name="sponsor_method" required class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold text-playful-ink shadow-sm">
          <option value="">{sponsorModal.methodPlaceholder}</option>
          {sponsorModal.methods.map((method) => <option value={method}>{method}</option>)}
        </select>
      </label>

      <label class="grid gap-2 text-sm font-extrabold text-playful-orange-dark">
        {sponsorModal.message}
        <textarea name="sponsor_message" rows="4" placeholder={sponsorModal.messagePlaceholder} class="playful-focus rounded-2xl border border-playful-line bg-white px-4 py-3 font-semibold leading-6 text-playful-ink shadow-sm"></textarea>
      </label>

      <div data-sponsor-success class="hidden rounded-2xl border border-green-200 bg-green-50 p-4 text-sm font-bold leading-6 text-green-800" aria-live="polite">
        {sponsorModal.sent}
      </div>

      <div data-sponsor-mailto-note class="hidden rounded-2xl border border-playful-line bg-white p-4 text-sm font-bold leading-6 text-playful-muted">
        <p>{sponsorModal.fallbackNote}</p>
        <a data-sponsor-mailto href={`mailto:${shelterEmail}`} class="playful-focus mt-3 inline-flex rounded-full bg-playful-orange px-5 py-3 font-playful-display text-sm font-extrabold text-white shadow-squish">
          {sponsorModal.fallback}
        </a>
      </div>

      <div class="flex flex-col gap-3 sm:flex-row sm:justify-end">
        <button data-sponsor-modal-close type="button" class="playful-focus rounded-full border-2 border-playful-orange bg-white px-6 py-3 font-playful-display text-sm font-extrabold text-playful-orange-dark shadow-pillowy">
          {sponsorModal.close}
        </button>
        <button data-sponsor-submit type="submit" class="squishy playful-focus rounded-full bg-playful-orange px-6 py-3 font-playful-display text-sm font-extrabold text-white shadow-squish disabled:cursor-wait disabled:opacity-70">
          {sponsorModal.submit}
        </button>
      </div>
    </form>
  </div>
</dialog>

<style is:global>
  dialog[data-sponsor-modal]::backdrop {
    background: rgb(29 27 22 / 0.54);
    backdrop-filter: blur(7px);
  }
</style>

<script define:vars={{ shelterEmail, sponsorModal, formApiBaseUrl }}>
  const sponsorDialog = document.querySelector('[data-sponsor-modal]');
  const sponsorOpenButtons = document.querySelectorAll('[data-sponsor-modal-open]');
  const sponsorCloseButtons = document.querySelectorAll('[data-sponsor-modal-close]');
  const sponsorForm = document.querySelector('[data-sponsor-form]');
  const sponsorMailtoLink = document.querySelector('[data-sponsor-mailto]');
  const sponsorMailtoNote = document.querySelector('[data-sponsor-mailto-note]');
  const sponsorSuccess = document.querySelector('[data-sponsor-success]');
  const sponsorSubmitButton = document.querySelector('[data-sponsor-submit]');

  const sponsorOpenDialog = () => {
    if (!sponsorDialog) return;
    if (typeof sponsorDialog.showModal === 'function') sponsorDialog.showModal();
    else sponsorDialog.setAttribute('open', '');
    sponsorDialog.querySelector('input, select, textarea, button')?.focus();
  };

  const sponsorCloseDialog = () => {
    if (!sponsorDialog) return;
    if (typeof sponsorDialog.close === 'function') sponsorDialog.close();
    else sponsorDialog.removeAttribute('open');
  };

  sponsorOpenButtons.forEach((button) => button.addEventListener('click', sponsorOpenDialog));
  sponsorCloseButtons.forEach((button) => button.addEventListener('click', sponsorCloseDialog));
  sponsorDialog?.addEventListener('click', (event) => {
    if (event.target === sponsorDialog) sponsorCloseDialog();
  });

  sponsorForm?.addEventListener('submit', async (event) => {
    event.preventDefault();
    if (!sponsorForm.reportValidity()) return;

    const data = new FormData(sponsorForm);
    const get = (name) => String(data.get(name) ?? '').trim();
    const businessValue = get('sponsor_business') === 'yes' ? sponsorModal.businessYes : sponsorModal.businessNo;
    const amount = get('sponsor_amount');
    const phone = get('sponsor_phone') || sponsorModal.notProvided;
    const message = get('sponsor_message') || sponsorModal.notProvided;

    const body = [
      sponsorModal.bodyIntro,
      '',
      `${sponsorModal.labels.name}: ${get('sponsor_name')}`,
      `${sponsorModal.labels.email}: ${get('sponsor_email')}`,
      `${sponsorModal.labels.phone}: ${phone}`,
      `${sponsorModal.labels.business}: ${businessValue}`,
      `${sponsorModal.labels.amount}: €${amount}${sponsorModal.perMonth}`,
      `${sponsorModal.labels.method}: ${get('sponsor_method')}`,
      `${sponsorModal.labels.message}: ${message}`,
      '',
      `${sponsorModal.page}: ${window.location.href}`,
    ].join('\n');

    const mailto = `mailto:${shelterEmail}?subject=${encodeURIComponent(sponsorModal.subject)}&body=${encodeURIComponent(body)}`;
    sponsorMailtoLink?.setAttribute('href', mailto);
    sponsorMailtoNote?.classList.add('hidden');
    sponsorSuccess?.classList.add('hidden');
    if (sponsorSubmitButton) {
      sponsorSubmitButton.disabled = true;
      sponsorSubmitButton.textContent = sponsorModal.sending;
    }

    let sent = false;
    if (formApiBaseUrl && sponsorForm.dataset.skipBackend !== 'true') {
      try {
        const response = await fetch(`${formApiBaseUrl}/forms/submit`, {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            kind: 'sponsorship',
            locale: document.documentElement.lang === 'en' ? 'en' : 'pt',
            source: 'home-sponsor-modal',
            pageUrl: window.location.href,
            contextLabel: sponsorModal.eyebrow,
            contextValue: sponsorModal.title,
            name: get('sponsor_name'),
            email: get('sponsor_email'),
            phone,
            amount: `€${amount}${sponsorModal.perMonth}`,
            business: businessValue,
            contributionMethod: get('sponsor_method'),
            message,
            website: get('website'),
          }),
        });
        const result = await response.json().catch(() => ({}));
        sent = response.ok && Boolean(result?.ok);
      } catch {
        sent = false;
      }
    }

    if (sponsorSubmitButton) {
      sponsorSubmitButton.disabled = false;
      sponsorSubmitButton.textContent = sponsorModal.submit;
    }

    if (sent) {
      sponsorForm.reset();
      sponsorSuccess?.classList.remove('hidden');
      sponsorSuccess?.focus?.();
      return;
    }

    sponsorMailtoNote?.classList.remove('hidden');
    sponsorMailtoLink?.focus();

    if (sponsorForm.dataset.skipMailLaunch !== 'true') {
      window.location.href = mailto;
    }
  });
</script>
