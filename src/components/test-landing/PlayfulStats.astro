---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);

const stats = [
  { number: 315, label: t.stats.sterilizedLabel, sublabel: t.stats.sterilizedSub, accent: 'text-playful-orange-dark', bg: 'bg-white', rotate: 'md:rotate-1', icon: '✚' },
  { number: 419, label: t.stats.adoptedLabel, sublabel: t.stats.adoptedSub, accent: 'text-playful-orange', bg: 'bg-playful-cream', rotate: 'md:-rotate-1 md:translate-y-4', icon: '❤' },
  { number: 135, label: t.stats.shelterLabel, sublabel: t.stats.shelterSub, accent: 'text-playful-watermelon-dark', bg: 'bg-white', rotate: 'md:rotate-2', icon: '⌂' },
];
---

<section class="relative px-5 py-14 sm:px-8 lg:py-20" aria-labelledby="playful-stats-heading">
  <div class="mx-auto max-w-7xl">
    <div class="mb-10 text-center">
      <h2 id="playful-stats-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.04em] text-playful-orange-dark sm:text-5xl">{t.stats.heading}</h2>
      <p class="mx-auto mt-3 max-w-2xl text-base font-medium text-playful-muted sm:text-lg">{t.stats.subheading}</p>
    </div>

    <div class="grid grid-cols-1 gap-6 md:grid-cols-3 lg:gap-8">
      {stats.map(({ number, label, sublabel, accent, bg, rotate, icon }) => (
        <article class={`${bg} ${rotate} card-pillowy rounded-playful border border-playful-line/70 p-7 text-center shadow-pillowy`}>
          <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-playful-peach text-xl shadow-sm" aria-hidden="true">{icon}</div>
          <div class={`mb-1 font-playful-display text-6xl font-extrabold leading-none ${accent}`}>{number}</div>
          <h3 class="font-playful-display text-xl font-extrabold text-playful-orange-dark">{label}</h3>
          <p class="mt-1 text-sm font-medium text-playful-muted">{sublabel}</p>
        </article>
      ))}
    </div>
  </div>
</section>
