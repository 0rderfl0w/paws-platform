---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);

const aboutPath = locale === 'pt' ? '/sobre-nos' : '/en/about';
const helpPath = locale === 'pt' ? '/ajudar' : '/en/help';

const stats = [
  { value: t.aboutBlurb.stat1Value, label: t.aboutBlurb.stat1Label, rotate: '-rotate-2' },
  { value: t.aboutBlurb.stat2Value, label: t.aboutBlurb.stat2Label, rotate: 'rotate-1' },
  { value: t.aboutBlurb.stat3Value, label: t.aboutBlurb.stat3Label, rotate: 'rotate-2' },
  { value: t.aboutBlurb.stat4Value, label: t.aboutBlurb.stat4Label, rotate: '-rotate-1' },
];
---

<section id="sobre-nos" class="relative px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="playful-about-heading">
  <div class="mx-auto max-w-7xl">
    <div data-reveal="tilt" class="relative overflow-hidden rounded-[2.5rem] border border-playful-line bg-playful-peach/58 p-6 shadow-pillowy-lg sm:p-10 lg:p-14">
      <div class="ambient-blob -left-20 -top-20 h-64 w-64 bg-white"></div>
      <div class="ambient-blob -bottom-24 -right-20 h-80 w-80 bg-playful-orange/28"></div>

      <div class="relative z-10 grid items-center gap-10 lg:grid-cols-[1.08fr_0.92fr]">
        <div data-reveal="left" data-reveal-delay="80">
          <span class="mb-3 inline-block rounded-full bg-white/80 px-4 py-2 text-xs font-extrabold uppercase tracking-[0.22em] text-playful-orange-dark shadow-sm">{t.aboutBlurb.eyebrow}</span>
          <h2 id="playful-about-heading" class="max-w-3xl font-playful-display text-4xl font-extrabold tracking-[-0.04em] text-playful-orange-dark sm:text-5xl">{t.aboutBlurb.heading}</h2>
          <div class="mt-6 space-y-4 text-lg font-medium leading-8 text-playful-muted">
            <p>{t.aboutBlurb.p1}</p>
            <p>{t.aboutBlurb.p2}</p>
          </div>
          <div class="mt-8 flex flex-col gap-3 sm:flex-row">
            <a href={aboutPath} class="squishy playful-focus inline-flex items-center justify-center rounded-full bg-playful-orange px-6 py-3 font-extrabold text-white shadow-squish">{t.aboutBlurb.ctaPrimary}</a>
            <a href={helpPath} class="squishy playful-focus inline-flex items-center justify-center rounded-full bg-white/85 px-6 py-3 font-extrabold text-playful-orange-dark shadow-pillowy">{t.aboutBlurb.ctaSecondary}</a>
          </div>
        </div>

        <div data-reveal-stagger="90" class="grid grid-cols-2 gap-4">
          {stats.map(({ value, label, rotate }) => (
            <div data-reveal="pop" class={`${rotate} card-pillowy rounded-full border border-playful-line bg-white px-5 py-7 text-center shadow-pillowy`}>
              <div class="font-playful-display text-3xl font-extrabold text-playful-orange-dark sm:text-4xl">{value}</div>
              <div class="mt-2 text-xs font-bold uppercase tracking-[0.12em] text-playful-muted">{label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
