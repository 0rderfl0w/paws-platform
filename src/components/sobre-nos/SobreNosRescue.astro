---
import type { AboutContent } from './sobreNosContent';

interface Props {
  content: AboutContent['rescue'];
}

const { content } = Astro.props;
const images = [
  '/images/sobre-nos/rescued-dog.png',
  '/images/sobre-nos/dog-recovery.jpg',
  '/images/sobre-nos/volunteers-at-shelter.png',
];
---

<section class="relative overflow-hidden px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="rescue-heading">
  <div class="ambient-blob right-0 top-16 h-80 w-80 bg-playful-orange/15"></div>

  <div class="relative z-10 mx-auto max-w-7xl">
    <header data-reveal="rise" class="mb-10 text-center">
      <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{content.eyebrow}</p>
      <h2 id="rescue-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.05em] text-playful-ink sm:text-5xl">
        {content.heading}
      </h2>
    </header>

    <div class="grid gap-8 lg:grid-cols-[1.02fr_0.98fr] lg:items-center">
      <article data-reveal="left" class="rounded-[2.5rem] border border-playful-line/70 bg-white p-7 shadow-pillowy-lg sm:p-10">
        <div class="mb-7 flex h-16 w-16 items-center justify-center rounded-full bg-playful-peach text-3xl text-playful-orange-dark shadow-sm" aria-hidden="true">✚</div>
        <div class="space-y-5 text-lg font-medium leading-8 text-playful-muted">
          {content.paragraphs.map((paragraph, index) => (
            <p class={index === 0 ? 'text-playful-ink' : ''}>{paragraph}</p>
          ))}
        </div>
      </article>

      <div data-reveal="right" class="grid gap-4 sm:grid-cols-2">
        {images.map((src, index) => (
          <figure class={`overflow-hidden rounded-[2rem] border-[7px] border-white bg-playful-cream shadow-pillowy ${index === 2 ? 'sm:col-span-2' : ''} ${index === 0 ? '-rotate-2' : index === 1 ? 'rotate-2 sm:translate-y-6' : '-rotate-1'}`}>
            <img src={src} alt={content.imageAlts[index]} loading="lazy" class={`w-full object-cover ${index === 2 ? 'aspect-[16/7]' : 'aspect-[4/3]'}`} />
          </figure>
        ))}
      </div>
    </div>

    <div data-reveal-stagger="90" class="mt-8 grid gap-4 sm:grid-cols-3">
      {content.quickStats.map(({ value, label }, index) => (
        <div data-reveal="pop" class={`rounded-[1.6rem] border border-playful-line/70 bg-playful-cream px-5 py-5 text-center shadow-sm ${index === 1 ? 'sm:translate-y-4' : ''}`}>
          <div class="font-playful-display text-xl font-extrabold text-playful-orange-dark">{value}</div>
          <div class="mt-1 text-sm font-semibold text-playful-muted">{label}</div>
        </div>
      ))}
    </div>
  </div>
</section>
