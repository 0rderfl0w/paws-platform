---
import { getTranslations, type Locale } from '../../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);
const statsEyebrow = locale === 'pt' ? 'CAPA em números' : 'CAPA by the numbers';
const stats = [
  { number: 315, label: t.stats.sterilizedLabel, sublabel: t.stats.sterilizedSub, icon: '✚', tilt: 'sm:-rotate-1' },
  { number: 419, label: t.stats.adoptedLabel, sublabel: t.stats.adoptedSub, icon: '❤', tilt: 'sm:rotate-1 sm:translate-y-4' },
  { number: 135, label: t.stats.shelterLabel, sublabel: t.stats.shelterSub, icon: '🏠', tilt: 'sm:-rotate-1' },
];
---

<section class="relative overflow-hidden px-5 py-16 sm:px-8 lg:py-20" aria-labelledby="stats-heading">
  <div class="ambient-blob left-0 top-12 h-64 w-64 bg-playful-peach/70"></div>
  <div class="relative z-10 mx-auto max-w-7xl">
    <header data-reveal="rise" class="mb-10 text-center">
      <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{statsEyebrow}</p>
      <h2 id="stats-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.05em] text-playful-ink sm:text-5xl">
        {t.stats.heading}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium leading-8 text-playful-muted">
        {t.stats.subheading}
      </p>
    </header>

    <div data-reveal-stagger="100" class="grid gap-6 sm:grid-cols-3 lg:gap-8">
      {stats.map(({ number, label, sublabel, icon, tilt }) => (
        <article data-reveal="pop" class={`${tilt} card-pillowy rounded-playful border border-playful-line/70 bg-white p-7 text-center shadow-pillowy`}>
          <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-playful-peach text-2xl font-extrabold text-playful-orange-dark shadow-sm" aria-hidden="true">{icon}</div>
          <div class="font-playful-display text-5xl font-extrabold tracking-[-0.05em] text-playful-orange-dark">{number}</div>
          <div class="mt-2 text-xl font-extrabold text-playful-ink">{label}</div>
          <div class="mt-1 text-sm font-semibold text-playful-muted">{sublabel}</div>
        </article>
      ))}
    </div>
  </div>
</section>
