---
import type { AboutContent } from './sobreNosContent';

interface Props {
  content: AboutContent['community'];
}

const { content } = Astro.props;
---

<section class="relative overflow-hidden px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="community-heading">
  <div class="ambient-blob left-0 bottom-0 h-80 w-80 bg-playful-peach/70"></div>

  <div class="relative z-10 mx-auto grid max-w-7xl items-center gap-10 rounded-[2.75rem] border border-playful-line/70 bg-white/82 p-6 shadow-pillowy-lg sm:p-10 lg:grid-cols-[0.96fr_1.04fr] lg:gap-14">
    <div data-reveal="left">
      <p class="mb-4 inline-flex rotate-[-1deg] rounded-full bg-playful-peach px-4 py-2 text-xs font-extrabold uppercase tracking-[0.22em] text-playful-orange-dark shadow-sm">
        {content.eyebrow}
      </p>
      <h2 id="community-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.05em] text-playful-ink sm:text-5xl">
        {content.heading}
      </h2>
      <div class="mt-6 space-y-5 text-lg font-medium leading-8 text-playful-muted">
        {content.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
      </div>
      <a href="mailto:capa.geralpvl@gmail.com" class="squishy playful-focus mt-8 inline-flex items-center justify-center gap-2 rounded-full bg-playful-orange px-7 py-4 font-playful-display font-extrabold text-white shadow-squish">
        {content.cta}
        <span aria-hidden="true">✉</span>
      </a>
    </div>

    <div data-reveal="right" class="relative min-h-[420px] sm:min-h-[500px] lg:min-h-[560px]" aria-label="CAPA community photography">
      <div class="absolute left-0 top-0 w-[72%] overflow-hidden rounded-[2.25rem] border-[8px] border-white bg-playful-cream shadow-pillowy-lg rotate-[-2deg]">
        <img src="/images/sobre-nos/volunteers-landscape.jpg" alt={content.imageAlt} width="1680" height="1121" loading="lazy" class="aspect-[4/3] h-full w-full object-cover object-center" />
      </div>
      <div class="absolute bottom-3 right-0 w-[48%] overflow-hidden rounded-[2rem] border-[8px] border-white bg-playful-cream shadow-pillowy-lg rotate-3">
        <img src="/images/sobre-nos/community-event.png" alt={content.supportAlt} width="454" height="880" loading="lazy" class="aspect-[3/4] h-full w-full object-cover object-center" />
      </div>
      <div class="absolute right-8 top-8 rounded-full bg-playful-orange px-5 py-3 text-sm font-extrabold text-white shadow-squish rotate-2">
        CAPA PVL
      </div>
    </div>
  </div>
</section>
