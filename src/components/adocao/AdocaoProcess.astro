---
import type { AdocaoContent } from './adocaoContent';

interface Props {
  content: AdocaoContent['process'];
}

const { content } = Astro.props;
---

<section id="processo-adocao" class="relative overflow-hidden px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="process-heading">
  <div class="ambient-blob -left-20 top-20 h-96 w-96 bg-playful-peach/70"></div>
  <div class="ambient-blob right-0 bottom-4 h-72 w-72 bg-playful-watermelon/18"></div>

  <div class="mx-auto max-w-7xl">
    <header data-reveal="rise" class="relative z-10 mb-12 text-center">
      <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{content.eyebrow}</p>
      <h2 id="process-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.05em] text-playful-ink sm:text-5xl">
        {content.heading}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium leading-8 text-playful-muted">
        {content.intro}
      </p>
    </header>

    <div data-reveal-stagger="90" class="relative z-10 grid gap-5 lg:grid-cols-3">
      {content.steps.map(({ title, description }, index) => (
        <article data-adocao-step data-reveal="tilt" class={`card-pillowy rounded-[2rem] border border-playful-line/70 bg-white p-6 shadow-pillowy ${index % 2 === 0 ? 'lg:-rotate-1' : 'lg:rotate-1 lg:translate-y-5'}`}>
          <div class="mb-5 flex items-center gap-4">
            <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-full bg-playful-orange font-playful-display text-2xl font-extrabold text-white shadow-squish">
              {index + 1}
            </div>
            <h3 class="font-playful-display text-xl font-extrabold tracking-[-0.03em] text-playful-orange-dark">{title}</h3>
          </div>
          <p class="text-sm font-semibold leading-6 text-playful-muted">{description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
