---
import type { AdocaoContent } from './adocaoContent';

interface Props {
  content: AdocaoContent['benefits'];
}

const { content } = Astro.props;
---

<section class="relative overflow-hidden px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="benefits-heading">
  <div class="ambient-blob -right-16 top-20 h-80 w-80 bg-playful-orange/15"></div>
  <div class="mx-auto max-w-7xl">
    <header data-reveal="rise" class="relative z-10 mb-12 text-center">
      <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{content.eyebrow}</p>
      <h2 id="benefits-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.05em] text-playful-ink sm:text-5xl">
        {content.heading}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium leading-8 text-playful-muted">
        {content.intro}
      </p>
    </header>

    <div data-reveal-stagger="85" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3">
      {content.cards.map(({ title, description, icon, tone }) => (
        <article data-adocao-benefit data-reveal="tilt" class={`${tone} card-pillowy rounded-playful border border-playful-line/70 p-7 shadow-pillowy`}>
          <div class="mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-playful-orange/12 text-2xl font-extrabold text-playful-orange-dark shadow-sm" aria-hidden="true">{icon}</div>
          <h3 class="mb-3 font-playful-display text-xl font-extrabold tracking-[-0.03em] text-playful-orange-dark">{title}</h3>
          <p class="text-sm font-semibold leading-6 text-playful-muted">{description}</p>
        </article>
      ))}
    </div>
  </div>
</section>
