---
import type { AdocaoContent } from './adocaoContent';

interface Props {
  content: AdocaoContent['fees'];
}

const { content } = Astro.props;
---

<section class="relative overflow-hidden px-5 py-16 sm:px-8 lg:py-24" aria-labelledby="fees-heading">
  <div class="ambient-blob -right-24 top-12 h-80 w-80 bg-playful-orange/20"></div>
  <div class="mx-auto max-w-6xl">
    <header data-reveal="rise" class="relative z-10 mb-12 text-center">
      <p class="mb-3 text-xs font-extrabold uppercase tracking-[0.24em] text-playful-orange-dark">{content.eyebrow}</p>
      <h2 id="fees-heading" class="font-playful-display text-4xl font-extrabold tracking-[-0.05em] text-playful-ink sm:text-5xl">
        {content.heading}
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-lg font-medium leading-8 text-playful-muted">
        {content.intro}
      </p>
    </header>

    <div data-reveal-stagger="110" class="relative z-10 grid gap-6 md:grid-cols-3">
      {content.cards.map(({ title, price, icon, tone, inclusions, note }) => (
        <article data-adocao-fee data-reveal="tilt" class={`${tone} card-pillowy rounded-[2.25rem] border border-playful-line/70 p-7 text-center shadow-pillowy`}>
          <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-playful-orange/12 font-playful-display text-3xl font-extrabold text-playful-orange-dark shadow-sm" aria-hidden="true">{icon}</div>
          <h3 class="font-playful-display text-2xl font-extrabold tracking-[-0.04em] text-playful-orange-dark">{title}</h3>
          <p class="my-4 font-playful-display text-5xl font-extrabold tracking-[-0.06em] text-playful-orange">{price}</p>
          <ul class="space-y-3 text-left text-sm font-bold leading-6 text-playful-muted" role="list">
            {inclusions.map((item) => (
              <li class="flex items-center gap-2 rounded-full bg-white/70 px-4 py-2">
                <span class="text-playful-orange-dark" aria-hidden="true">✓</span>
                <span>{item}</span>
              </li>
            ))}
          </ul>
          {note && <p class="mt-5 text-xs font-bold leading-5 text-playful-muted/82">{note}</p>}
        </article>
      ))}
    </div>

    <p data-reveal="rise" class="relative z-10 mx-auto mt-10 max-w-2xl rounded-full border border-playful-line bg-white/82 px-5 py-4 text-center text-sm font-bold leading-6 text-playful-muted shadow-sm">
      {content.contactPrefix}
      <a href={`mailto:${content.contactEmail}`} class="playful-focus rounded-full text-playful-orange-dark underline decoration-playful-orange/40 decoration-2 underline-offset-4 hover:text-playful-orange">{content.contactEmail}</a>
    </p>
  </div>
</section>
