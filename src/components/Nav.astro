---
import { getTranslations, getAlternatePath, locales, type Locale } from '../i18n';

interface Props {
  locale?: Locale;
}

const { locale = 'pt' } = Astro.props;
const t = getTranslations(locale);

const homePath = locale === 'pt' ? '/' : '/en/';
const dogsPath = locale === 'pt' ? '/caes' : '/en/dogs';
const aboutPath = locale === 'pt' ? '/sobre-nos' : '/en/about';
const helpPath = locale === 'pt' ? '/ajudar' : '/en/help';

const navLinks = [
  { href: homePath, label: t.nav.home },
  { href: dogsPath, label: t.nav.dogs },
  { href: aboutPath, label: t.nav.about },
  { href: helpPath, label: t.nav.help },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm border-b border-warm-200 shadow-sm">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8" aria-label={t.nav.mainNav}>
    <div class="flex items-center justify-between h-16">

      <!-- Logo + Name -->
      <a href={homePath} class="flex items-center gap-3 group" aria-label="CAPA Póvoa de Lanhoso — Página inicial">
        <img src="/logo.jpg" alt="CAPA Póvoa de Lanhoso" class="w-10 h-10 rounded-xl object-cover shadow-sm" width="40" height="40">
        <div class="leading-tight">
          <span class="block text-lg font-bold text-warm-900 group-hover:text-primary-600 transition-colors">CAPA</span>
          <span class="block text-xs text-warm-500 font-medium">Póvoa de Lanhoso</span>
        </div>
      </a>

      <!-- Desktop Nav Links -->
      <ul class="hidden md:flex items-center gap-1" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                currentPath === href
                  ? 'bg-primary-50 text-primary-700'
                  : 'text-warm-700 hover:bg-warm-100 hover:text-warm-900'
              }`}
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Desktop: Language Switcher + CTA -->
      <div class="hidden md:flex items-center gap-3">
        <!-- Language Switcher -->
        <div class="flex items-center gap-1 bg-warm-100 rounded-lg p-1">
          {locales.map(({ code, label, flag }) => {
            const altPath = getAlternatePath(currentPath, code);
            const isActive = code === locale;
            return (
              <a
                href={altPath}
                title={label}
                aria-label={label}
                class={`flex items-center justify-center w-8 h-8 rounded-md text-base transition-all ${
                  isActive
                    ? 'bg-white shadow-sm ring-1 ring-warm-200'
                    : 'hover:bg-warm-50 opacity-60 hover:opacity-100'
                }`}
                aria-current={isActive ? 'true' : undefined}
              >
                {flag}
              </a>
            );
          })}
        </div>

        <!-- CTA Button -->
        <a
          href={helpPath}
          class="inline-flex items-center px-4 py-2 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg shadow-sm transition-colors"
        >
          {t.nav.helpNow}
        </a>
      </div>

      <!-- Mobile Hamburger -->
      <button
        id="mobile-menu-btn"
        type="button"
        class="md:hidden p-2 rounded-lg text-warm-600 hover:bg-warm-100 hover:text-warm-900 transition-colors"
        aria-label={t.nav.openMenu}
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <svg id="hamburger-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <svg id="close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-6 h-6 hidden" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>

    <!-- Mobile Menu -->
    <div id="mobile-menu" class="hidden md:hidden border-t border-warm-200 py-3 pb-4">
      <!-- Mobile Language Switcher -->
      <div class="flex items-center gap-2 px-4 py-2 mb-1">
        {locales.map(({ code, label, flag }) => {
          const altPath = getAlternatePath(currentPath, code);
          const isActive = code === locale;
          return (
            <a
              href={altPath}
              title={label}
              aria-label={label}
              class={`flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium transition-all ${
                isActive
                  ? 'bg-primary-50 text-primary-700 ring-1 ring-primary-200'
                  : 'text-warm-600 hover:bg-warm-100'
              }`}
              aria-current={isActive ? 'true' : undefined}
            >
              <span>{flag}</span>
              <span>{label}</span>
            </a>
          );
        })}
      </div>

      <ul class="flex flex-col gap-1" role="list">
        {navLinks.map(({ href, label }) => (
          <li>
            <a
              href={href}
              class={`block px-4 py-2.5 rounded-lg text-sm font-medium transition-colors ${
                currentPath === href
                  ? 'bg-primary-50 text-primary-700'
                  : 'text-warm-700 hover:bg-warm-100 hover:text-warm-900'
              }`}
              aria-current={currentPath === href ? 'page' : undefined}
            >
              {label}
            </a>
          </li>
        ))}
        <li class="pt-2 border-t border-warm-200 mt-2">
          <a
            href={helpPath}
            class="block px-4 py-2.5 bg-primary-500 hover:bg-primary-600 text-white text-sm font-semibold rounded-lg text-center transition-colors"
          >
            {t.nav.helpNow}
          </a>
        </li>
      </ul>
    </div>
  </nav>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const hamburgerIcon = document.getElementById('hamburger-icon');
  const closeIcon = document.getElementById('close-icon');

  if (btn && menu && hamburgerIcon && closeIcon) {
    btn.addEventListener('click', () => {
      const isOpen = menu.classList.toggle('hidden') === false;
      btn.setAttribute('aria-expanded', String(isOpen));
      hamburgerIcon.classList.toggle('hidden', isOpen);
      closeIcon.classList.toggle('hidden', !isOpen);
    });
  }
</script>
